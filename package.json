{
  "name": "m4rkim-album",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev":        "vite",
    "dev:api":    "node --watch server/src/index.js",
    "dev:all":    "concurrently -n frontend,api -c cyan,yellow \"vite\" \"node --watch server/src/index.js\"",
    "build":      "vite build",
    "preview":    "vite preview",
    "start":      "NODE_ENV=production node server/src/index.js",
    "db:generate":"prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push":    "prisma db push",
    "db:seed":    "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.16.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.3.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "three": "^0.165.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "^5.16.2",
    "vite": "^5.3.0"
  }
}
